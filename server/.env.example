# Meta Conversions API Configuration
# Copy this file to .env and fill in your values

# Your Meta Pixel ID
META_PIXEL_ID=1684145446350033

# Conversions API system user access token
# Generate at: Business Settings > System Users > Generate Token
# Required permissions: ads_management
# NEVER commit this value to source control
META_ACCESS_TOKEN=your_access_token_here

# Server port (default: 3001)
PORT=3001
